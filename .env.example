# Path to the main application configuration file
CONFIG_PATH=./config/config.yaml

# Path where reasoning/thought signatures are stored
SIGNATURE_STORE_PATH=./data/thought-signatures.json

# API key for Brave search engine integration (optional)
BRAVE_API_KEY=

# API key for Tavily search engine integration (optional)
TAVILY_API_KEY=

# URL of the SearXNG search engine instance (optional)
SEARXNG_URL=http://localhost:8080

# Secret key used by SearXNG (for docker-compose setup)
SEARXNG_SECRET=
